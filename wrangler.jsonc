    "KNT_MIGRATION_EXPECTED_LEGACY_POWER": "65346806.123652943211440508",
    "KNT_MIGRATION_BASE_RELEASE_BP": "10",
    "KNT_MIGRATION_ACCEL_RELEASE_BP": "50",
    "KNT_MIGRATION_ACCEL_DIRECT_LP_USDT": "3000",
    "KNT_NEW_LP_POWER_PER_USDT": "6"
