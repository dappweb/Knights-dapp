{
  "name": "knights-dapp-contracts",
  "private": true,
  "type": "module",
  "version": "0.1.0",
  "scripts": {
    "compile": "hardhat compile",
    "deploy:knt:bsc:testnet": "npm run deploy:knt:all-in-one:bsc:testnet",
    "deploy:knt:all-in-one:bsc:testnet": "hardhat run scripts/deploy-knt-all-in-one-bsc-testnet.cjs --network bscTestnet",
    "deploy:knt:all-in-one:local": "hardhat run scripts/deploy-knt-all-in-one-bsc-testnet.cjs",
    "deploy:pancake:test-pool:bsc:testnet": "hardhat run scripts/deploy-pancake-test-pool-bsc-testnet.cjs --network bscTestnet",
    "deploy:knt:upgradeable:migrate:bsc:testnet": "hardhat run scripts/deploy-knt-upgradeable-migrate-bsc-testnet.cjs --network bscTestnet",
    "deploy:knt:upgradeable:bsc:mainnet": "hardhat run scripts/deploy-knt-upgradeable-bsc-mainnet.cjs --network bscMainnet",
    "upgrade:knt:upgradeable:bsc:mainnet": "hardhat run scripts/upgrade-knt-upgradeable-bsc-mainnet.cjs --network bscMainnet",
    "upgrade:knt:upgradeable:bsc:testnet": "hardhat run scripts/upgrade-knt-upgradeable-bsc-testnet.cjs --network bscTestnet",
    "admin:freeze-legacy:bsc:testnet": "hardhat run scripts/freeze-legacy-knt-bsc-testnet.cjs --network bscTestnet",
    "admin:set-liquidity:bsc:mainnet": "hardhat run scripts/admin-set-liquidity-config-bsc-mainnet.cjs --network bscMainnet",
    "migration:build:knt:mainnet": "node scripts/build-knt-mainnet-migration-state.cjs",
    "migration:import:knt:mainnet": "hardhat run scripts/import-knt-mainnet-migration.cjs --network bscMainnet",
    "migration:export-holders": "node scripts/export-token-holders-from-logs.cjs",
    "test:local": "hardhat test",
    "test:knt:business:bsc:testnet": "hardhat run scripts/test-knt-business-bsc-testnet.cjs --network bscTestnet",
    "test:knt:rewards:local": "hardhat run scripts/test-knt-reward-tax-local.cjs",
    "test:knt:upgradeable:local": "hardhat run scripts/test-knt-upgradeable-local.cjs",
    "test:knt:upgradeable:rewards:bsc:testnet": "hardhat run scripts/test-knt-upgradeable-rewards-bsc-testnet.cjs --network bscTestnet",
    "test:knt:50-deposits:bsc:testnet": "hardhat run scripts/test-knt-50-usdt-deposit-bsc-testnet.cjs --network bscTestnet",
    "admin:update-pool:bsc:testnet": "hardhat run scripts/admin-update-pool-bsc-testnet.cjs --network bscTestnet",
    "keeper:process-usdt:bsc:testnet": "hardhat run scripts/keeper-process-usdt-deposits-bsc-testnet.cjs --network bscTestnet",
    "keeper:maintenance:bsc:testnet": "hardhat run scripts/keeper-maintenance-bsc-testnet.cjs --network bscTestnet",
    "admin:server": "node --no-warnings=ExperimentalWarning src/admin/server.mjs",
    "admin:import-state": "node --no-warnings=ExperimentalWarning src/admin/import-state.mjs",
    "deploy:linux": "bash infra/linux/deploy.sh",
    "keeper:scheduled": "node --no-warnings=ExperimentalWarning src/admin/cron.mjs",
    "dev:cloudflare": "wrangler dev",
    "dev:cloudflare:production": "wrangler dev --env production",
    "deploy:cloudflare": "wrangler deploy --env production",
    "deploy:cloudflare:testnet": "wrangler deploy",
    "deploy:cloudflare:production": "wrangler deploy --env production",
    "cf:kv:create": "wrangler kv namespace create KNT_ADMIN_STATE"
  },
  "dependencies": {
    "@openzeppelin/contracts": "5.2.0",
    "@openzeppelin/contracts-upgradeable": "5.2.0",
    "dotenv": "^17.2.3",
    "ethers": "^6.16.0"
  },
  "devDependencies": {
    "@nomicfoundation/hardhat-ethers": "^3.1.2",
    "hardhat": "^2.27.0",
    "wrangler": "^4.0.0"
  }
}
